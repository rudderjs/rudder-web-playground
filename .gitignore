# Build output
dist/

# Dependencies
node_modules/

# Environment
.env
.env.*
!.env.example

# Forge CLI state (color rotation persistence)
.forge-cli-state.json

# Cache & tooling
.turbo/
*.log
dev.db
# But DO commit prisma/dev.db — pre-pushed schema for the WebContainer boot path,
# since the migration engine is a Rust binary that won't run in StackBlitz's
# sandbox. Re-push and re-commit when the Prisma schema changes.
!prisma/dev.db
.telescope.db
.telescope.db-shm
.telescope.db-wal
bootstrap/cache/

# Storage uploads
storage/app/
public/storage

# NOTE: prisma/generated/ IS committed in this standalone repo. The new
# prisma-client generator emits a binary-free ESM client, but `prisma
# generate` itself still pulls schema-engine from binaries.prisma.sh, which
# StackBlitz/WebContainer can't reach (no CORS). Pre-committing the output
# lets `pnpm install` skip generation entirely. Same trade-off as
# prisma/dev.db: regenerate locally on schema changes and re-commit.

# Playwright
test-results/

# NOTE: pages/__view/ is auto-generated by @rudderjs/vite from app/Views/**.
# Do NOT gitignore it — Vike uses `git ls-files` to discover pages and skips
# anything in .gitignore, which would 404 every controller-returned view.
# Commit these files; the scanner keeps them in sync on file changes.
